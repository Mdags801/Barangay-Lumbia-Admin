{
  "cleanUrls": true,
  "functions": {
    "**/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/(config|session_guard|vercel).json",
      "status": 403
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/",
      "dest": "/index.php"
    },
    {
      "src": "/login",
      "dest": "/login.php"
    }
  ]
}
