{
  "functions": {
    "**/*.php": {
      "runtime": "juicy-fx/vercel-php@latest"
    }
  },
  "routes": [
    {
      "src": "/(config|session_guard|vercel).json",
      "status": 403
    },
    {
      "src": "/api/(.*).php",
      "dest": "/api/$1.php"
    },
    {
      "src": "/(.*).(css|js|png|jpg|jpeg|gif|svg|ico|webp|ttf|woff|woff2)",
      "dest": "/$1.$2"
    },
    {
      "src": "/",
      "dest": "/index.php"
    },
    {
      "src": "/login",
      "dest": "/login.php"
    },
    {
      "src": "/((?!api|config|session_guard|.*\\.).*)",
      "dest": "/$1.php"
    }
  ]
}
