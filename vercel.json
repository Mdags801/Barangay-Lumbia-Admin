{
  "cleanUrls": true,
  "trailingSlash": false,
  "builds": [
    { "src": "api/*.php", "use": "vercel-php@0.7.1" },
    { "src": "*.php", "use": "vercel-php@0.7.1" },
    { "src": "**", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/", "destination": "/index.php" },
    { "source": "/api/:path((?!.*\\.).*)", "destination": "/api/:path.php" },
    { "source": "/:path((?!.*\\.).*)", "destination": "/:path.php" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
