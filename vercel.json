{
  "version": 2,
  "builds": [
    { "src": "api/*.php", "use": "vercel-php@0.7.1" },
    { "src": "*.php", "use": "vercel-php@0.7.1" },
    { "src": "!( *.php )", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/send_otp.php", "dest": "/api/send_otp.php" },
    { "src": "/api/verify_otp.php", "dest": "/api/verify_otp.php" },
    { "src": "/api/(.*).php", "dest": "/api/$1.php" },
    { "src": "/api/([^.]+)", "dest": "/api/$1.php" },
    { "src": "/(.*).php", "dest": "/$1.php" },
    { "src": "/(.*).(css|js|png|jpg|svg|ico)", "dest": "/$1.$2" },
    { "src": "/", "dest": "/index.php" },
    { "src": "/([^.]+)", "dest": "/$1.php" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
