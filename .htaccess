# ─────────────────────────────────────────────────────────────────────────────
# .htaccess — BBERS Security Configuration
# Implements: Clickjacking defence, XSS protection, CSP, CSRF mitigations
# ─────────────────────────────────────────────────────────────────────────────

# Block direct browser access to server-only PHP files
<Files "config.php">
    Order Allow,Deny
    Deny from all
</Files>

<Files "session_guard.php">
    Order Allow,Deny
    Deny from all
</Files>

# Block directory listings (prevents information disclosure)
Options -Indexes

# ─── Security Headers ─────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    # Clickjacking defence — only allow framing from same origin
    Header always set X-Frame-Options "SAMEORIGIN"

    # Prevent MIME-type sniffing (XSS vector)
    Header always set X-Content-Type-Options "nosniff"

    # Limit referrer info leakage
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Enable browser XSS filter (legacy but harmless)
    Header always set X-XSS-Protection "1; mode=block"

    # Content Security Policy — restrict script/style sources
    # Allows: self, Supabase CDN, Google Fonts, jsDelivr CDN, MapTiler
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' https://cdn.jsdelivr.net https://unpkg.com blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net; img-src 'self' data: blob: https://*.supabase.co https://*.maptiler.com https://tile.openstreetmap.org; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.maptiler.com; frame-ancestors 'self'; object-src 'none'; base-uri 'self';"

    # Permissions Policy — restrict browser feature access
    Header always set Permissions-Policy "geolocation=(self), camera=(), microphone=(), payment=()"

    # HSTS — force HTTPS for 1 year (enable only when HTTPS is confirmed)
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ─── PHP Session Hardening ────────────────────────────────────────────────────
<IfModule mod_php.c>
    php_value session.use_strict_mode 1
    php_value session.cookie_httponly 1
    php_value session.cookie_samesite "Lax"
    php_value session.use_only_cookies 1
</IfModule>
