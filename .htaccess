# Block direct browser access to config and session scripts
<Files "config.php">
    Order Allow,Deny
    Deny from all
</Files>

<Files "session_guard.php">
    Order Allow,Deny
    Deny from all
</Files>

# Block access to api/ folder listings
Options -Indexes

# Security Headers
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
